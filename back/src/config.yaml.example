log:
  level: "debug"
  path: "./logs/crypto.log"
  days: 7   # remove old logs after N days
  size: 10   # megabytes

db:
  host: "localhost"
  port: 8123
  user: "user"
  password: "pass"
  database: "default"

analyzer:
  threads: 3
  pair: "SOLUSDT"
  timeframe: "4h"
  minCloses: 100
  minSignals: 100
  takeprofit:
    start: 5.0
    end: 30.0
    step: 1.0
  stoploss:
    start: 5.0
    end: 30.0
    step: 1.0

  indicators:
    # 1-ая группа индикаторов
    -
      - type: sma
        coefs:
          start: 3.0
          end: 15.0
          step: 1.0
        sources:
          - low
          - open
          - close
          - high

      - type: ema
        coefs:
          start: 0.2
          end: 1.5
          step: 0.1
        sources:
          - low
          - open
          - close
          - high
      - type: dema
        coefs:
          start: 0.2
          end: 1.5
          step: 0.1
        sources:
          - low
          - open
          - close
          - high

      - type: tema
        coefs:
          start: 0.2
          end: 1.5
          step: 0.1
        sources:
          - low
          - open
          - close
          - high

      - type: temaZero
        coefs:
          start: 0.2
          end: 1.6
          step: 0.1
        sources:
          - low
          - open
          - close
          - high

    # 2-ая группа индикаторов
    -
      - type: sma
        coefs:
          start: 3.0
          end: 15.0
          step: 1.0
        sources:
          - low
          - open
          - close
          - high

      - type: ema
        coefs:
          start: 0.2
          end: 1.5
          step: 0.1
        sources:
          - low
          - open
          - close
          - high
      - type: dema
        coefs:
          start: 0.2
          end: 1.5
          step: 0.1
        sources:
          - low
          - open
          - close
          - high

      - type: tema
        coefs:
          start: 0.2
          end: 1.5
          step: 0.1
        sources:
          - low
          - open
          - close
          - high

      - type: temaZero
        coefs:
          start: 0.2
          end: 1.6
          step: 0.1
        sources:
          - low
          - open
          - close
          - high
